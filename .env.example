# Copy to `.env` at the repo root and fill in. `.env` is gitignored.
#
# These variables are loaded by scripts/obsidian-sync.sh and
# scripts/obsidian-push.sh, and read directly by the Python scripts via
# os.environ.

# ----- Workspace -----------------------------------------------------------
# Absolute path to your agent's workspace (the dir that holds MEMORY.md etc).
WORKSPACE=/root/.openclaw/workspace

# ----- S3-compatible vault -------------------------------------------------
# Hippius example:
#   S3_ENDPOINT=https://s3.hippius.com
#   S3_BUCKET=my-agent-memory
# AWS example:
#   S3_ENDPOINT=https://s3.eu-west-1.amazonaws.com
#   S3_BUCKET=my-agent-memory
S3_ENDPOINT=https://s3.hippius.com
S3_BUCKET=CHANGE-ME-your-bucket-name
S3_ACCESS_KEY=CHANGE-ME
S3_SECRET_KEY=CHANGE-ME

# Key prefix inside the bucket. Trailing slash required.
# Obsidian will mount this as the vault root.
VAULT_PREFIX=agent/

# ----- Qdrant (vector store) ----------------------------------------------
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# ----- Ollama (local embeddings, never cloud) -----------------------------
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ----- Optional ------------------------------------------------------------
# Re-mine workspace into Qdrant after each successful obsidian-sync.
QDRANT_REINDEX=1
